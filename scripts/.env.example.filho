# BIT ADICT — config do bot DIRECIONAL v2 (PC do filho)
# RENOMEIA esse arquivo pra .env (sem .example.filho) na pasta C:\BIT_ADICT\

# === WALLET POLYMARKET DO FILHO (separada da do Rafael!) ===
# 1. Cria nova wallet no polymarket.com (Sign up novo)
# 2. Settings > Show Keys > copia private key + funder address aqui
POLY_KEY=cole_a_private_key_aqui
POLY_FUNDER=0xcole_o_endereco_funder_aqui

# === BANCA INICIAL pequena pro filho ($10-20) ===
VALOR_TRADE=0.5
BANCA_MIN=8

# === MODO ===
# false = LIVE (dinheiro real), true = PAPER (simulado)
DRY_RUN=false
SKIP_BALANCE_CHECK=true

# === SINAIS (Telegram opcional pro Rafael acompanhar) ===
# Deixa em branco se nao quiser notificacoes
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# === LOG ===
LOG_PATH=C:\BIT_ADICT\logs\direcional_filho.log

# Auto-gerado: 2026-05-20
# Suporte: WhatsApp +55 61 99811-0979
